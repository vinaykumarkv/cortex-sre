# CortexSRE environment template
# Copy to .env and fill in real values. Never commit .env.

# demo | production
CORTEX_ENV=demo

# --- Sentry (https://sentry.io/settings/account/api/auth-tokens/) ---
# Scopes: event:read, project:read (fetch issues) + project:write (resolve issues)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- GitHub (https://github.com/settings/tokens) ---
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_DEFAULT_BRANCH=main

# --- Slack (https://api.slack.com/apps) ---
SLACK_BOT_TOKEN=
# Channel name without # (dotenv treats # as comment) or use channel ID C0123...
SLACK_INCIDENT_CHANNEL=incident-alerts
SLACK_DEV_CHANNEL=dev-channel

# --- Ollama (local LLM for code healing) ---
USE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Coral CLI ---
CORAL_USE_CLI=true

# --- GitHub PR automation (after healing) ---
GITHUB_PR_ENABLED=true

# --- Optional: Coral ---
# Run: python scripts/setup_coral.py && coral spec apply coral/*.yaml

# --- Optional: production repo clone target for healer ---
# CORTEX_WORKSPACE_DIR=./workspace_checkout
